apiVersion: v1
kind: Secret
metadata:
  name: mysql-secret
type: Opaque
data:
  # Base64-encode your real values: echo -n 'yourvalue' | base64
  MYSQL_ROOT_PASSWORD: <base64-encoded-root-password>
  MYSQL_DATABASE: ZXhhbV9kYg==
  MYSQL_USER: YXBwX3VzZXI=
  MYSQL_PASSWORD: <base64-encoded-app-password>
